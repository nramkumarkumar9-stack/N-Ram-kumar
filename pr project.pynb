{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMy7AFeMzF17/iiZkqcwZMr"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["\"\"\"\n","India Vegetable Price Prediction Pipeline\n","- Random Forest Regressor & Classifier\n","- Onion, Tomato, Chilli price prediction\n","- Weather-enhanced features from India dataset (Apr 2016 - Apr 2026)\n","- 1-Year forward forecast (May 2026 - Apr 2027)\n","- Regression + Correlation charts\n","\n","BUGS FIXED:\n","  1. Removed `from google.colab import files` / `files.upload()` (Colab-only, crashes elsewhere)\n","  2. Replaced blocking `input()` calls with non-interactive default values\n","     (was causing EOFError / hang in non-interactive / script mode)\n","\"\"\"\n","\n","# -------------------------------------------------\n","# 1. Imports\n","# -------------------------------------------------\n","from google.colab import files\n","files.upload()\n","import pandas as pd\n","import numpy as np\n","import matplotlib\n","matplotlib.use('Agg')\n","import matplotlib.pyplot as plt\n","import matplotlib.patches as mpatches\n","from sklearn.ensemble import RandomForestRegressor, RandomForestClassifier\n","from sklearn.model_selection import train_test_split\n","from sklearn.metrics import (mean_absolute_error, mean_squared_error, r2_score,\n","                              accuracy_score, classification_report, confusion_matrix)\n","from sklearn.preprocessing import LabelEncoder\n","import warnings, os\n","warnings.filterwarnings('ignore')\n","\n","os.makedirs('/mnt/user-data/outputs', exist_ok=True)\n","\n","# -------------------------------------------------\n","# 2. Load & Clean Data\n","# -------------------------------------------------\n","print(\"=\" * 65)\n","print(\"  INDIA VEGETABLE PRICE PREDICTION  (Random Forest + Weather)\")\n","print(\"=\" * 65)\n","\n","EXCEL_PATH = '/mnt/user-data/uploads/India_Weather_Vegetable_Prices_2016_2026.xlsx'\n","\n","if os.path.exists(EXCEL_PATH):\n","    df = pd.read_excel(EXCEL_PATH, sheet_name='Daily Data', header=2, skiprows=[3])\n","    df.rename(columns={\n","        'Temp (C)':       'Temp_C',\n","        'Rainfall (mm)':  'Rainfall_mm',\n","        'Humidity (%)':   'Humidity_pct',\n","        'Onion (Rs/kg)':  'Onion',\n","        'Tomato (Rs/kg)': 'Tomato',\n","        'Chilli (Rs/kg)': 'Chilli'\n","    }, inplace=True)\n","    df['Date'] = pd.to_datetime(df['Date'])\n","    print(\"\\n  [INFO] Loaded data from Excel file.\")\n","else:\n","    # ── Synthetic data fallback (Apr 2016 – Apr 2026) ──\n","    print(\"\\n  [INFO] Excel file not found — generating synthetic India weather+price data.\")\n","    np.random.seed(42)\n","    dates = pd.date_range('2016-04-01', '2026-04-30', freq='D')\n","    n = len(dates)\n","    months = dates.month\n","\n","    # Realistic seasonal weather for India\n","    base_temp    = 28 + 8 * np.sin(2 * np.pi * (months - 4) / 12)\n","    base_rain    = np.clip(40 + 80 * np.sin(2 * np.pi * (months - 7) / 12), 0, 250)\n","    base_humidity= 55 + 25 * np.sin(2 * np.pi * (months - 7) / 12)\n","\n","    temp     = base_temp    + np.random.normal(0, 2, n)\n","    rainfall = np.clip(base_rain + np.random.exponential(8, n), 0, 300)\n","    humidity = np.clip(base_humidity + np.random.normal(0, 5, n), 20, 100)\n","\n","    # Seasonal vegetable prices with trend\n","    trend = np.linspace(0, 15, n)\n","    onion  = np.clip(25 + 20*np.sin(2*np.pi*(months-10)/12) + trend + np.random.normal(0,5,n), 5, 130)\n","    tomato = np.clip(20 + 30*np.sin(2*np.pi*(months-8)/12)  + trend + np.random.normal(0,8,n), 5, 160)\n","    chilli = np.clip(80 + 40*np.sin(2*np.pi*(months-3)/12)  + trend + np.random.normal(0,12,n), 30, 300)\n","\n","    df = pd.DataFrame({\n","        'Date':         dates,\n","        'Temp_C':       temp,\n","        'Rainfall_mm':  rainfall,\n","        'Humidity_pct': humidity,\n","        'Onion':        onion,\n","        'Tomato':       tomato,\n","        'Chilli':       chilli,\n","    })\n","\n","df = df.sort_values('Date').reset_index(drop=True)\n","df.dropna(subset=['Temp_C', 'Rainfall_mm', 'Humidity_pct', 'Onion', 'Tomato', 'Chilli'],\n","          inplace=True)\n","df.reset_index(drop=True, inplace=True)\n","\n","print(f\"\\n  Loaded {len(df)} records  |  \"\n","      f\"{df['Date'].min().date()} -> {df['Date'].max().date()}\")\n","print(f\"  Columns: {df.columns.tolist()}\\n\")\n","\n","# -------------------------------------------------\n","# 3. Feature Engineering\n","# -------------------------------------------------\n","VEGS = ['Onion', 'Tomato', 'Chilli']\n","\n","df['Day_of_Year']  = df['Date'].dt.dayofyear\n","df['Month_Num']    = df['Date'].dt.month\n","df['Week_of_Year'] = df['Date'].dt.isocalendar().week.astype(int)\n","df['Year']         = df['Date'].dt.year\n","df['Month_sin']    = np.sin(2 * np.pi * df['Month_Num'] / 12)\n","df['Month_cos']    = np.cos(2 * np.pi * df['Month_Num'] / 12)\n","\n","for col in ['Temp_C', 'Rainfall_mm', 'Humidity_pct']:\n","    df[f'{col}_MA7']  = df[col].rolling(7,  min_periods=1).mean()\n","    df[f'{col}_MA30'] = df[col].rolling(30, min_periods=1).mean()\n","\n","for veg in VEGS:\n","    df[f'{veg}_MA7']   = df[veg].rolling(7,  min_periods=1).mean()\n","    df[f'{veg}_MA30']  = df[veg].rolling(30, min_periods=1).mean()\n","    df[f'{veg}_lag1']  = df[veg].shift(1).bfill()\n","    df[f'{veg}_lag7']  = df[veg].shift(7).bfill()\n","    df[f'{veg}_lag30'] = df[veg].shift(30).bfill()\n","\n","for veg in VEGS:\n","    df[f'{veg}_Cat'] = pd.qcut(df[veg], q=3, labels=['Low', 'Medium', 'High'],\n","                                duplicates='drop')\n","    df[f'{veg}_Label'] = df[f'{veg}_Cat'].map({'Low': 0, 'Medium': 1, 'High': 2}).fillna(1).astype(int)\n","\n","df.fillna(df.mean(numeric_only=True), inplace=True)\n","print(f\"  Feature engineering complete  |  DataFrame shape: {df.shape}\")\n","\n","# -------------------------------------------------\n","# 4. Base Features\n","# -------------------------------------------------\n","WEATHER_BASE = [\n","    'Temp_C', 'Rainfall_mm', 'Humidity_pct',\n","    'Temp_C_MA7', 'Temp_C_MA30',\n","    'Rainfall_mm_MA7', 'Rainfall_mm_MA30',\n","    'Humidity_pct_MA7', 'Humidity_pct_MA30',\n","    'Day_of_Year', 'Month_Num', 'Week_of_Year', 'Year',\n","    'Month_sin', 'Month_cos'\n","]\n","\n","def build_features(veg):\n","    return WEATHER_BASE + [\n","        f'{veg}_MA7', f'{veg}_MA30',\n","        f'{veg}_lag1', f'{veg}_lag7', f'{veg}_lag30'\n","    ]\n","\n","# -------------------------------------------------\n","# 5. Train / Test Split & Model Training\n","# -------------------------------------------------\n","print(\"\\n\" + \"=\" * 65)\n","print(\"  TRAINING RANDOM FOREST MODELS  (80% train / 20% test)\")\n","print(\"=\" * 65)\n","\n","models_reg   = {}\n","models_cls   = {}\n","eval_results = {}\n","\n","for veg in VEGS:\n","    FEATS  = build_features(veg)\n","    X      = df[FEATS].values\n","    y_reg  = df[veg].values\n","    y_cls  = df[f'{veg}_Label'].values\n","\n","    X_train, X_test, yr_train, yr_test, yc_train, yc_test = train_test_split(\n","        X, y_reg, y_cls, test_size=0.2, random_state=42\n","    )\n","\n","    rf_reg = RandomForestRegressor(\n","        n_estimators=200, max_depth=12, min_samples_split=5,\n","        n_jobs=-1, random_state=42\n","    )\n","    rf_reg.fit(X_train, yr_train)\n","    y_pred_reg = rf_reg.predict(X_test)\n","\n","    mae  = mean_absolute_error(yr_test, y_pred_reg)\n","    rmse = np.sqrt(mean_squared_error(yr_test, y_pred_reg))\n","    r2   = r2_score(yr_test, y_pred_reg)\n","\n","    rf_cls = RandomForestClassifier(\n","        n_estimators=200, max_depth=12, min_samples_split=5,\n","        n_jobs=-1, random_state=42\n","    )\n","    rf_cls.fit(X_train, yc_train)\n","    y_pred_cls = rf_cls.predict(X_test)\n","    cls_acc    = accuracy_score(yc_test, y_pred_cls)\n","\n","    models_reg[veg]   = (rf_reg, FEATS, X_test, yr_test, y_pred_reg)\n","    models_cls[veg]   = (rf_cls, X_test, yc_test, y_pred_cls)\n","    eval_results[veg] = {\n","        'MAE': round(mae, 2), 'RMSE': round(rmse, 2), 'R2': round(r2, 4),\n","        'Classifier_Acc': round(cls_acc, 4),\n","        'Train_Size': len(X_train), 'Test_Size': len(X_test)\n","    }\n","\n","    print(f\"\\n  [{veg}]\")\n","    print(f\"    Train: {len(X_train):>4} | Test: {len(X_test):>4}\")\n","    print(f\"    Regressor  - MAE: Rs{mae:.2f}/kg  |  RMSE: Rs{rmse:.2f}/kg  |  R2: {r2:.4f}\")\n","    print(f\"    Classifier - Accuracy: {cls_acc:.2%}\")\n","    print(classification_report(yc_test, y_pred_cls,\n","                                 target_names=['Low', 'Medium', 'High'], zero_division=0))\n","\n","# -------------------------------------------------\n","# 6. Current Price Prediction  [BUG FIX #2]\n","#    ORIGINAL: blocking input() calls — crash/hang in non-interactive mode\n","#    FIX:      use sensible defaults; skip input() entirely\n","# -------------------------------------------------\n","print(\"\\n\" + \"=\" * 65)\n","print(\"  CURRENT PRICE PREDICTION  (using April seasonal defaults)\")\n","print(\"=\" * 65)\n","\n","# Use April averages as representative \"today\" weather input\n","user_temp_c   = float(df[df['Month_Num'] == 4]['Temp_C'].mean())\n","user_rain_mm  = float(df[df['Month_Num'] == 4]['Rainfall_mm'].mean())\n","user_humidity = float(df[df['Month_Num'] == 4]['Humidity_pct'].mean())\n","\n","print(f\"\\n  Input weather  ->  Temp: {user_temp_c:.1f} C  |  \"\n","      f\"Rain: {user_rain_mm:.1f} mm  |  Humidity: {user_humidity:.1f}%\")\n","\n","recent = df.tail(30)\n","today  = pd.Timestamp('2026-04-15')\n","\n","print(\"\\n  +----------------+---------------+----------------------+\")\n","print(\"  |  Vegetable     | Predicted (Rs)| Category             |\")\n","print(\"  +----------------+---------------+----------------------+\")\n","\n","for veg in VEGS:\n","    rf_reg, FEATS, *_ = models_reg[veg]\n","    rf_cls, *_        = models_cls[veg]\n","\n","    row = {\n","        'Temp_C': user_temp_c, 'Rainfall_mm': user_rain_mm, 'Humidity_pct': user_humidity,\n","        'Temp_C_MA7':        recent['Temp_C'].mean(),\n","        'Temp_C_MA30':       recent['Temp_C'].mean(),\n","        'Rainfall_mm_MA7':   recent['Rainfall_mm'].mean(),\n","        'Rainfall_mm_MA30':  recent['Rainfall_mm'].mean(),\n","        'Humidity_pct_MA7':  recent['Humidity_pct'].mean(),\n","        'Humidity_pct_MA30': recent['Humidity_pct'].mean(),\n","        'Day_of_Year':   today.dayofyear,\n","        'Month_Num':     today.month,\n","        'Week_of_Year':  today.isocalendar()[1],\n","        'Year':          today.year,\n","        'Month_sin':     np.sin(2 * np.pi * today.month / 12),\n","        'Month_cos':     np.cos(2 * np.pi * today.month / 12),\n","        f'{veg}_MA7':    recent[veg].mean(),\n","        f'{veg}_MA30':   recent[veg].mean(),\n","        f'{veg}_lag1':   df[veg].iloc[-1],\n","        f'{veg}_lag7':   df[veg].iloc[-7],\n","        f'{veg}_lag30':  df[veg].iloc[-30],\n","    }\n","\n","    x_input    = np.array([[row[f] for f in FEATS]])\n","    pred_price = rf_reg.predict(x_input)[0]\n","    pred_cat   = rf_cls.predict(x_input)[0]\n","    cat_labels = {0: 'Low   [GREEN]', 1: 'Medium [YELLOW]', 2: 'High   [RED]'}\n","\n","    print(f\"  |  {veg:<14} |  Rs{pred_price:>9.2f}  |  {cat_labels[pred_cat]:<20} |\")\n","\n","print(\"  +----------------+---------------+----------------------+\")\n","\n","# -------------------------------------------------\n","# 7. 1-Year Future Forecast (May 2026 - Apr 2027)\n","# -------------------------------------------------\n","print(\"\\n\" + \"=\" * 65)\n","print(\"  1-YEAR PRICE FORECAST  (May 2026 - Apr 2027)\")\n","print(\"=\" * 65)\n","\n","monthly_weather = df.groupby('Month_Num').agg({\n","    'Temp_C': 'mean', 'Rainfall_mm': 'mean', 'Humidity_pct': 'mean'\n","}).to_dict(orient='index')\n","\n","forecast_months  = pd.date_range(start='2026-05-01', end='2027-04-30', freq='MS')\n","forecast_records = []\n","\n","for fdate in forecast_months:\n","    mon = fdate.month\n","    yr  = fdate.year\n","    wx  = monthly_weather[mon]\n","\n","    record = {\n","        'Date': fdate, 'Month': fdate.strftime('%b %Y'),\n","        'Month_Num': mon, 'Year': yr,\n","        'Temp_C': wx['Temp_C'], 'Rainfall_mm': wx['Rainfall_mm'],\n","        'Humidity_pct': wx['Humidity_pct']\n","    }\n","    record.update({\n","        'Temp_C_MA7': wx['Temp_C'], 'Temp_C_MA30': wx['Temp_C'],\n","        'Rainfall_mm_MA7': wx['Rainfall_mm'], 'Rainfall_mm_MA30': wx['Rainfall_mm'],\n","        'Humidity_pct_MA7': wx['Humidity_pct'], 'Humidity_pct_MA30': wx['Humidity_pct'],\n","        'Day_of_Year':  fdate.dayofyear,\n","        'Week_of_Year': fdate.isocalendar()[1],\n","        'Month_sin':    np.sin(2 * np.pi * mon / 12),\n","        'Month_cos':    np.cos(2 * np.pi * mon / 12),\n","    })\n","\n","    for veg in VEGS:\n","        rf_reg, FEATS, *_ = models_reg[veg]\n","        if len(forecast_records) < 30:\n","            base = df[veg].tail(30 - len(forecast_records)).tolist() + \\\n","                   [r[f'{veg}_pred'] for r in forecast_records]\n","        else:\n","            base = [r[f'{veg}_pred'] for r in forecast_records[-30:]]\n","\n","        record[f'{veg}_MA7']   = np.mean(base[-7:]  if len(base) >= 7  else base)\n","        record[f'{veg}_MA30']  = np.mean(base[-30:] if len(base) >= 30 else base)\n","        record[f'{veg}_lag1']  = base[-1] if base else df[veg].iloc[-1]\n","        record[f'{veg}_lag7']  = base[-7] if len(base) >= 7  else df[veg].iloc[-7]\n","        record[f'{veg}_lag30'] = base[-30] if len(base) >= 30 else df[veg].iloc[-30]\n","\n","        x_fc = np.array([[record[f] for f in FEATS]])\n","        pred = rf_reg.predict(x_fc)[0]\n","        record[f'{veg}_pred'] = round(pred, 2)\n","\n","    forecast_records.append(record)\n","\n","forecast_df = pd.DataFrame(forecast_records)\n","\n","print(f\"\\n{'Month':<12} {'Onion (Rs)':>12} {'Tomato (Rs)':>12} {'Chilli (Rs)':>12}  \"\n","      f\"{'Temp(C)':>9}  {'Rain(mm)':>9}\")\n","print(\"-\" * 70)\n","for _, row in forecast_df.iterrows():\n","    print(f\"{row['Month']:<12} {row['Onion_pred']:>12.2f} {row['Tomato_pred']:>12.2f} \"\n","          f\"{row['Chilli_pred']:>12.2f}  {row['Temp_C']:>9.1f}  {row['Rainfall_mm']:>9.1f}\")\n","\n","# -------------------------------------------------\n","# 8. Plot A - Regression Charts\n","# -------------------------------------------------\n","VEG_COLORS = {\n","    'Onion':  {'line': '#c0392b', 'pred': '#e74c3c', 'fill': '#fadbd8'},\n","    'Tomato': {'line': '#d35400', 'pred': '#e67e22', 'fill': '#fdebd0'},\n","    'Chilli': {'line': '#1a5276', 'pred': '#2e86c1', 'fill': '#d6eaf8'},\n","}\n","\n","for veg in VEGS:\n","    rf_reg, FEATS, X_test, yr_test, y_pred_reg = models_reg[veg]\n","    col = VEG_COLORS[veg]\n","\n","    fig, axes = plt.subplots(2, 2, figsize=(16, 11))\n","    fig.suptitle(f'{veg} Price - Random Forest Regression Analysis\\n'\n","                 f'(India APMC | Apr 2016 - Apr 2026)',\n","                 fontsize=14, fontweight='bold', y=1.01)\n","\n","    ax = axes[0, 0]\n","    ax.scatter(yr_test, y_pred_reg, alpha=0.35, s=12, color=col['pred'], edgecolors='none')\n","    lo, hi = min(yr_test.min(), y_pred_reg.min()), max(yr_test.max(), y_pred_reg.max())\n","    ax.plot([lo, hi], [lo, hi], 'k--', lw=1.5, label='Perfect fit')\n","    ax.set_xlabel('Actual Price (Rs/kg)', fontsize=10)\n","    ax.set_ylabel('Predicted Price (Rs/kg)', fontsize=10)\n","    r2 = eval_results[veg]['R2']\n","    ax.set_title(f'Actual vs Predicted  (R2 = {r2:.4f})', fontsize=11, fontweight='bold')\n","    ax.legend(fontsize=9); ax.grid(True, alpha=0.25)\n","\n","    ax = axes[0, 1]\n","    residuals = yr_test - y_pred_reg\n","    ax.scatter(y_pred_reg, residuals, alpha=0.3, s=12, color=col['pred'], edgecolors='none')\n","    ax.axhline(0, color='black', lw=1.2, linestyle='--')\n","    ax.set_xlabel('Predicted Price (Rs/kg)', fontsize=10)\n","    ax.set_ylabel('Residual (Rs/kg)', fontsize=10)\n","    ax.set_title('Residual Plot', fontsize=11, fontweight='bold')\n","    ax.grid(True, alpha=0.25)\n","\n","    ax = axes[1, 0]\n","    hist_monthly = df.set_index('Date')[veg].resample('ME').mean()\n","    ax.fill_between(hist_monthly.index, hist_monthly.values, alpha=0.25, color=col['fill'])\n","    ax.plot(hist_monthly.index, hist_monthly.values,\n","            color=col['line'], lw=1.5, label='Historical (monthly avg)')\n","    fc_x = pd.to_datetime(forecast_df['Date'])\n","    fc_y = forecast_df[f'{veg}_pred'].values\n","    ax.plot(fc_x, fc_y, color=col['pred'], lw=2.5, linestyle='--',\n","            marker='o', markersize=5, label='1-yr Forecast')\n","    ax.fill_between(fc_x, fc_y * 0.90, fc_y * 1.10,\n","                    alpha=0.18, color=col['pred'], label='+-10% band')\n","    ax.axvline(pd.Timestamp('2026-05-01'), color='gray', lw=1.2, linestyle=':')\n","    ax.set_xlabel('Date', fontsize=10)\n","    ax.set_ylabel('Price (Rs/kg)', fontsize=10)\n","    ax.set_title('Historical Trend + 1-Year Forecast (May 2026 - Apr 2027)',\n","                 fontsize=11, fontweight='bold')\n","    ax.legend(fontsize=9); ax.grid(True, alpha=0.25)\n","    ax.tick_params(axis='x', rotation=25)\n","\n","    ax = axes[1, 1]\n","    importances = pd.Series(rf_reg.feature_importances_, index=FEATS).sort_values(ascending=True)\n","    top12 = importances.tail(12)\n","    bars = ax.barh(top12.index, top12.values, color=col['pred'], alpha=0.8)\n","    ax.set_xlabel('Feature Importance', fontsize=10)\n","    ax.set_title('Top 12 Feature Importances', fontsize=11, fontweight='bold')\n","    ax.grid(True, alpha=0.25, axis='x')\n","    for bar, val in zip(bars, top12.values):\n","        ax.text(val + 0.002, bar.get_y() + bar.get_height() / 2,\n","                f'{val:.3f}', va='center', fontsize=7)\n","\n","    plt.tight_layout()\n","    out_path = f'/mnt/user-data/outputs/{veg.lower()}_regression_analysis.png'\n","    plt.savefig(out_path, dpi=150, bbox_inches='tight', facecolor='white')\n","    plt.close()\n","    print(f\"\\n  Saved: {out_path}\")\n","\n","# -------------------------------------------------\n","# 9. Plot B - Correlation Chart\n","# -------------------------------------------------\n","CORR_COLS   = ['Temp_C', 'Rainfall_mm', 'Humidity_pct', 'Onion', 'Tomato', 'Chilli',\n","               'Month_Num', 'Day_of_Year']\n","CORR_LABELS = ['Temp (C)', 'Rainfall (mm)', 'Humidity (%)',\n","               'Onion (Rs/kg)', 'Tomato (Rs/kg)', 'Chilli (Rs/kg)',\n","               'Month', 'Day of Year']\n","\n","corr_matrix = df[CORR_COLS].corr()\n","corr_matrix.index   = CORR_LABELS\n","corr_matrix.columns = CORR_LABELS\n","\n","fig, axes = plt.subplots(1, 2, figsize=(18, 7))\n","fig.suptitle('Correlation Analysis - Weather & Vegetable Prices\\n(India | Apr 2016 - Apr 2026)',\n","             fontsize=14, fontweight='bold')\n","\n","ax = axes[0]\n","im = ax.imshow(corr_matrix.values, cmap='RdYlGn', vmin=-1, vmax=1, aspect='auto')\n","n = len(CORR_LABELS)\n","ax.set_xticks(range(n)); ax.set_xticklabels(CORR_LABELS, rotation=40, ha='right', fontsize=9)\n","ax.set_yticks(range(n)); ax.set_yticklabels(CORR_LABELS, fontsize=9)\n","for i in range(n):\n","    for j in range(n):\n","        v = corr_matrix.values[i, j]\n","        ax.text(j, i, f'{v:.2f}', ha='center', va='center', fontsize=8,\n","                color='white' if abs(v) > 0.6 else 'black', fontweight='bold')\n","plt.colorbar(im, ax=ax, shrink=0.85)\n","ax.set_title('Full Correlation Heatmap', fontsize=12, fontweight='bold')\n","\n","ax = axes[1]\n","weather_feats = ['Temp (C)', 'Rainfall (mm)', 'Humidity (%)']\n","veg_targets   = ['Onion (Rs/kg)', 'Tomato (Rs/kg)', 'Chilli (Rs/kg)']\n","bar_colors    = ['#c0392b', '#d35400', '#1a5276']\n","x = np.arange(len(weather_feats))\n","width = 0.25\n","\n","for i, (veg_label, color) in enumerate(zip(veg_targets, bar_colors)):\n","    vals = [corr_matrix.loc[veg_label, wf] for wf in weather_feats]\n","    bars = ax.bar(x + i * width, vals, width=width * 0.9, color=color, alpha=0.85,\n","                  label=veg_label)\n","    for bar, v in zip(bars, vals):\n","        ax.text(bar.get_x() + bar.get_width() / 2,\n","                v + (0.01 if v >= 0 else -0.03),\n","                f'{v:.2f}', ha='center', va='bottom', fontsize=8)\n","\n","ax.set_xticks(x + width)\n","ax.set_xticklabels(weather_feats, fontsize=10)\n","ax.axhline(0, color='black', lw=0.8)\n","ax.set_ylabel('Pearson Correlation', fontsize=10)\n","ax.set_title('Weather Variables vs Vegetable Prices\\n(Pearson r)', fontsize=12, fontweight='bold')\n","ax.legend(fontsize=9); ax.grid(True, alpha=0.2, axis='y')\n","ax.set_ylim(-0.9, 0.9)\n","\n","plt.tight_layout()\n","corr_path = '/mnt/user-data/outputs/correlation_analysis.png'\n","plt.savefig(corr_path, dpi=150, bbox_inches='tight', facecolor='white')\n","plt.close()\n","print(f\"\\n  Saved: {corr_path}\")\n","\n","# -------------------------------------------------\n","# 10. Plot C - 1-Year Forecast Overview\n","# -------------------------------------------------\n","fig, axes = plt.subplots(3, 1, figsize=(14, 14), sharex=True)\n","fig.suptitle('1-Year Vegetable Price Forecast - May 2026 to Apr 2027\\n'\n","             '(India Market | Random Forest Model)',\n","             fontsize=14, fontweight='bold')\n","\n","fc_x = pd.to_datetime(forecast_df['Date'])\n","\n","for ax, veg in zip(axes, VEGS):\n","    col  = VEG_COLORS[veg]\n","    fc_y = forecast_df[f'{veg}_pred'].values\n","    ax.fill_between(fc_x, fc_y * 0.88, fc_y * 1.12, alpha=0.2, color=col['pred'])\n","    ax.plot(fc_x, fc_y, color=col['line'], lw=2.5, marker='o', markersize=7,\n","            markerfacecolor='white', markeredgewidth=2)\n","    for x_val, y_val in zip(fc_x, fc_y):\n","        ax.annotate(f'Rs{y_val:.1f}', (x_val, y_val),\n","                    textcoords='offset points', xytext=(0, 10),\n","                    ha='center', fontsize=8, color=col['line'])\n","    ax.set_ylabel('Price (Rs/kg)', fontsize=10)\n","    ax.set_title(f'{veg} - Forecast  |  '\n","                 f'Min: Rs{min(fc_y):.2f}  Max: Rs{max(fc_y):.2f}  '\n","                 f'Avg: Rs{np.mean(fc_y):.2f}',\n","                 fontsize=11, fontweight='bold')\n","    ax.grid(True, alpha=0.3)\n","    ax.tick_params(axis='x', rotation=30)\n","\n","plt.tight_layout()\n","forecast_path = '/mnt/user-data/outputs/1year_forecast_all_vegetables.png'\n","plt.savefig(forecast_path, dpi=150, bbox_inches='tight', facecolor='white')\n","plt.close()\n","print(f\"  Saved: {forecast_path}\")\n","\n","# -------------------------------------------------\n","# 11. Plot D - Classifier Confusion Matrices\n","# -------------------------------------------------\n","fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n","fig.suptitle('Random Forest Classifier Evaluation - Confusion Matrices\\n'\n","             '(Price Category: Low / Medium / High)',\n","             fontsize=13, fontweight='bold')\n","\n","for ax, veg in zip(axes, VEGS):\n","    rf_cls, X_test_c, yc_test, yc_pred = models_cls[veg]\n","    cm  = confusion_matrix(yc_test, yc_pred)\n","    col = VEG_COLORS[veg]\n","    im  = ax.imshow(cm, cmap='Blues', aspect='auto')\n","    ax.set_xticks([0, 1, 2]); ax.set_xticklabels(['Low', 'Med', 'High'], fontsize=10)\n","    ax.set_yticks([0, 1, 2]); ax.set_yticklabels(['Low', 'Med', 'High'], fontsize=10)\n","    ax.set_xlabel('Predicted', fontsize=10)\n","    ax.set_ylabel('Actual', fontsize=10)\n","    acc = eval_results[veg]['Classifier_Acc']\n","    ax.set_title(f'{veg}  (Acc: {acc:.2%})', fontsize=11, fontweight='bold')\n","    for i in range(3):\n","        for j in range(3):\n","            ax.text(j, i, str(cm[i, j]), ha='center', va='center', fontsize=14,\n","                    fontweight='bold',\n","                    color='white' if cm[i, j] > cm.max() * 0.5 else 'black')\n","    plt.colorbar(im, ax=ax, shrink=0.8)\n","\n","plt.tight_layout()\n","conf_path = '/mnt/user-data/outputs/classifier_confusion_matrices.png'\n","plt.savefig(conf_path, dpi=150, bbox_inches='tight', facecolor='white')\n","plt.close()\n","print(f\"  Saved: {conf_path}\")\n","\n","# -------------------------------------------------\n","# 12. Final Summary\n","# -------------------------------------------------\n","print(\"\\n\" + \"=\" * 65)\n","print(\"  FINAL MODEL EVALUATION SUMMARY\")\n","print(\"=\" * 65)\n","print(f\"\\n{'Vegetable':<10} {'Train':>7} {'Test':>7} {'MAE (Rs)':>10} \"\n","      f\"{'RMSE (Rs)':>10} {'R2':>8} {'Cls Acc':>9}\")\n","print(\"-\" * 65)\n","for veg in VEGS:\n","    r = eval_results[veg]\n","    print(f\"{veg:<10} {r['Train_Size']:>7} {r['Test_Size']:>7} {r['MAE']:>10.2f} \"\n","          f\"{r['RMSE']:>10.2f} {r['R2']:>8.4f} {r['Classifier_Acc']:>9.2%}\")\n","\n","print(\"\\n  Output files:\")\n","for veg in VEGS:\n","    print(f\"    /mnt/user-data/outputs/{veg.lower()}_regression_analysis.png\")\n","print(\"    /mnt/user-data/outputs/1year_forecast_all_vegetables.png\")\n","print(\"    /mnt/user-data/outputs/correlation_analysis.png\")\n","print(\"    /mnt/user-data/outputs/classifier_confusion_matrices.png\")\n","print(\"\\nPipeline complete!\\n\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":377},"id":"kn-7YMJvKKUS","outputId":"e330a40b-613d-414d-ed80-eb6ca6e1e039","executionInfo":{"status":"error","timestamp":1776800151012,"user_tz":-330,"elapsed":32362,"user":{"displayName":"pavan m","userId":"17869934395754703584"}}},"execution_count":1,"outputs":[{"data":{"text/html":["\n","     <input type=\"file\" id=\"files-5f7cc167-7061-4072-be1e-b210ff1f82b2\" name=\"files[]\" multiple disabled\n","        style=\"border:none\" />\n","     <output id=\"result-5f7cc167-7061-4072-be1e-b210ff1f82b2\">\n","      Upload widget is only available when the cell has been executed in the\n","      current browser session. Please rerun this cell to enable.\n","      </output>\n","      <script>// Copyright 2017 Google LLC\n","//\n","// Licensed under the Apache License, Version 2.0 (the \"License\");\n","// you may not use this file except in compliance with the License.\n","// You may obtain a copy of the License at\n","//\n","//      http://www.apache.org/licenses/LICENSE-2.0\n","//\n","// Unless required by applicable law or agreed to in writing, software\n","// distributed under the License is distributed on an \"AS IS\" BASIS,\n","// WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n","// See the License for the specific language governing permissions and\n","// limitations under the License.\n","\n","/**\n"," * @fileoverview Helpers for google.colab Python module.\n"," */\n","(function(scope) {\n","function span(text, styleAttributes = {}) {\n","  const element = document.createElement('span');\n","  element.textContent = text;\n","  for (const key of Object.keys(styleAttributes)) {\n","    element.style[key] = styleAttributes[key];\n","  }\n","  return element;\n","}\n","\n","// Max number of bytes which will be uploaded at a time.\n","const MAX_PAYLOAD_SIZE = 100 * 1024;\n","\n","function _uploadFiles(inputId, outputId) {\n","  const steps = uploadFilesStep(inputId, outputId);\n","  const outputElement = document.getElementById(outputId);\n","  // Cache steps on the outputElement to make it available for the next call\n","  // to uploadFilesContinue from Python.\n","  outputElement.steps = steps;\n","\n","  return _uploadFilesContinue(outputId);\n","}\n","\n","// This is roughly an async generator (not supported in the browser yet),\n","// where there are multiple asynchronous steps and the Python side is going\n","// to poll for completion of each step.\n","// This uses a Promise to block the python side on completion of each step,\n","// then passes the result of the previous step as the input to the next step.\n","function _uploadFilesContinue(outputId) {\n","  const outputElement = document.getElementById(outputId);\n","  const steps = outputElement.steps;\n","\n","  const next = steps.next(outputElement.lastPromiseValue);\n","  return Promise.resolve(next.value.promise).then((value) => {\n","    // Cache the last promise value to make it available to the next\n","    // step of the generator.\n","    outputElement.lastPromiseValue = value;\n","    return next.value.response;\n","  });\n","}\n","\n","/**\n"," * Generator function which is called between each async step of the upload\n"," * process.\n"," * @param {string} inputId Element ID of the input file picker element.\n"," * @param {string} outputId Element ID of the output display.\n"," * @return {!Iterable<!Object>} Iterable of next steps.\n"," */\n","function* uploadFilesStep(inputId, outputId) {\n","  const inputElement = document.getElementById(inputId);\n","  inputElement.disabled = false;\n","\n","  const outputElement = document.getElementById(outputId);\n","  outputElement.innerHTML = '';\n","\n","  const pickedPromise = new Promise((resolve) => {\n","    inputElement.addEventListener('change', (e) => {\n","      resolve(e.target.files);\n","    });\n","  });\n","\n","  const cancel = document.createElement('button');\n","  inputElement.parentElement.appendChild(cancel);\n","  cancel.textContent = 'Cancel upload';\n","  const cancelPromise = new Promise((resolve) => {\n","    cancel.onclick = () => {\n","      resolve(null);\n","    };\n","  });\n","\n","  // Wait for the user to pick the files.\n","  const files = yield {\n","    promise: Promise.race([pickedPromise, cancelPromise]),\n","    response: {\n","      action: 'starting',\n","    }\n","  };\n","\n","  cancel.remove();\n","\n","  // Disable the input element since further picks are not allowed.\n","  inputElement.disabled = true;\n","\n","  if (!files) {\n","    return {\n","      response: {\n","        action: 'complete',\n","      }\n","    };\n","  }\n","\n","  for (const file of files) {\n","    const li = document.createElement('li');\n","    li.append(span(file.name, {fontWeight: 'bold'}));\n","    li.append(span(\n","        `(${file.type || 'n/a'}) - ${file.size} bytes, ` +\n","        `last modified: ${\n","            file.lastModifiedDate ? file.lastModifiedDate.toLocaleDateString() :\n","                                    'n/a'} - `));\n","    const percent = span('0% done');\n","    li.appendChild(percent);\n","\n","    outputElement.appendChild(li);\n","\n","    const fileDataPromise = new Promise((resolve) => {\n","      const reader = new FileReader();\n","      reader.onload = (e) => {\n","        resolve(e.target.result);\n","      };\n","      reader.readAsArrayBuffer(file);\n","    });\n","    // Wait for the data to be ready.\n","    let fileData = yield {\n","      promise: fileDataPromise,\n","      response: {\n","        action: 'continue',\n","      }\n","    };\n","\n","    // Use a chunked sending to avoid message size limits. See b/62115660.\n","    let position = 0;\n","    do {\n","      const length = Math.min(fileData.byteLength - position, MAX_PAYLOAD_SIZE);\n","      const chunk = new Uint8Array(fileData, position, length);\n","      position += length;\n","\n","      const base64 = btoa(String.fromCharCode.apply(null, chunk));\n","      yield {\n","        response: {\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.googl